{
  "name": "h7ymcp",
  "version": "1.0.0",
  "description": "A safe-by-default personal MCP/App SDK-style connector for inspecting, editing, and handing off work inside a local dev workspace.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hodinhuy/h7ymcp.git"
  },
  "bugs": {
    "url": "https://github.com/hodinhuy/h7ymcp/issues"
  },
  "homepage": "https://github.com/hodinhuy/h7ymcp",
  "keywords": [
    "mcp",
    "chatgpt",
    "codex",
    "apps-sdk",
    "h7ymcp",
    "local-development",
    "cloudflare-tunnel",
    "ngrok"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs",
    "scripts",
    "README.md",
    "PUBLIC_LAUNCH_CHECKLIST.md",
    "DOMAIN_SETUP.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "FAQ.md",
    "FAQ_ZH.md",
    "CHANGELOG.md",
    "CHATGPT_PROMPT.md",
    "CODEX_PROMPT.md",
    "AGENTS.example.md",
    "config.example.env"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "h7ymcp": "scripts/codexpro.mjs",
    "h7ymcp-mcp": "dist/stdio.js",
    "h7ymcp-http": "dist/http.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:unit": "node --test \"test/**/*.test.mjs\"",
    "prepack": "npm run build",
    "start": "node dist/stdio.js",
    "start:stdio": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev:stdio": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "smoke": "node scripts/smoke.mjs && node scripts/http-smoke.mjs && node scripts/pro-smoke.mjs && node scripts/doctor-smoke.mjs && node scripts/settings-smoke.mjs && node scripts/execute-handoff-smoke.mjs",
    "doctor": "node scripts/codexpro.mjs doctor",
    "connect": "node scripts/codexpro.mjs",
    "connect:setup": "node scripts/codexpro.mjs setup",
    "connect:local": "node scripts/codexpro.mjs --tunnel none",
    "connect:cloudflare": "node scripts/codexpro.mjs --tunnel cloudflare",
    "connect:chatgpt": "node scripts/codexpro.mjs --tunnel cloudflare",
    "connect:stable": "node scripts/codexpro.mjs --tunnel cloudflare-named",
    "connect:ngrok": "node scripts/codexpro.mjs ngrok",
    "pro:bundle": "node scripts/pro-bundle.mjs",
    "pro:apply": "node scripts/pro-apply.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "minimatch": "^10.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
